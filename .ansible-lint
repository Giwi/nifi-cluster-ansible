# Ansible Lint configuration
skip_list:
  # Use fully qualified collection names (too verbose for small project)
  - fqcn
  # Use changed_when on command tasks (we handle this differently)
  - no-changed-when
  # Allow long lines in templates
  - line-length
  # Enable yaml rule (uses yamllint)
  - yaml

# Enable specific rules
enable_list:
  - no-log-password
  - deprecated-bare-vars

# Warnings (non-fatal)
warn_list:
  - truthy

# Ignore specific paths
exclude_paths:
  - .git/
  - .vscode/
  - files/
