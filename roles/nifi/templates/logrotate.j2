/var/lib/containers/storage/overlay-containers/*/userdata/ctr.log {
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
    sharedscripts
    postrotate
        podman restart nifi > /dev/null 2>&1 || true
    endscript
}

/opt/nifi/logs/*.log {
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
}
